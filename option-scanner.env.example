# 扫描范围
SCANNER_EXCHANGE=all
SCANNER_UNDERLYING=

# 调度与合约缓存（秒）
SCANNER_INTERVAL=60
SCANNER_CATALOG_TTL=21600
SCANNER_ONCE=0

# 网络与输出
SCANNER_WORKERS=8
SCANNER_RATE_LIMIT=8
SCANNER_LIMIT=20
SCANNER_ALERT_LIMIT=20
SCANNER_MAX_LOG_MB=100

# 0 = dry-run；1 = 发送飞书
SCANNER_NOTIFY=0
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# macOS 某些 Python 安装需要；Linux 通常留空即可
SSL_CERT_FILE=
